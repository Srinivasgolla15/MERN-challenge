<%layout("/layouts/boilerplate")%>

    <body>
        <br>
        <div class="row">
            <div class="col-8 offset-2">
                <h3>Create A New Listing</h3>
                <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
                    <div class="mt-3">
                        <label for="title" class="form-label">Title</label>
                        <input name="listing[title]" placeholder="enter title" type="text" class="form-control"
                            required>
                        <div class="invalid-feedback">
                            Please Enter the Title.
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="description" class="form-label" required>Description</label>
                        <textarea name="listing[description]" placeholder="enter description" class="form-control"
                            required></textarea>
                        <div class="invalid-feedback">
                            Please Enter the Description.
                        </div>
                    </div>

                    <!-- <div class="mt-3">
                        <label for="image" class="form-label">Image</label>
                        <input name="listing[image][url]" placeholder="enter url/link" type="text" class="form-control"
                            >
                        <div class="invalid-feedback">
                            Please paste the image url.
                        </div>
                    </div> -->
                    <div class="mt-3">
                        <label for="image" class="form-label">Image</label>
                        <input name="listing[image]" placeholder="enter url/link" type="file" class="form-control"
                            >
                        <div class="invalid-feedback">
                            Upload image.
                        </div>
                    </div>

                    <div class="row ">
                        <div class="mt-3 col-4">
                            <label for="price" class="form-label" required>Price</label>
                            <input name="listing[price]" required placeholder="enter price" type="number"
                                class="form-control">
                            <div class="invalid-feedback">
                                Please enter a valid Price.
                            </div>
                        </div>
                        <div class="mt-3 col-8">
                            <label for="country" class="form-label">Country</label>
                            <input name="listing[country]" id="country" required placeholder="enter Country" type="text"
                                class="form-control">
                            <div class="invalid-feedback">
                                Please enter your Country.
                            </div>
                        </div>
                    </div>


                    <div class="mt-3">
                        <label for="location" class="form-label">Location</label>
                        <input name="listing[location]" id="location" required placeholder="enter Location" type="text"
                            class="form-control">
                        <div class="invalid-feedback">
                            Please choose the location.
                        </div>
                    </div>

                    <!-- Hidden inputs for coordinates -->
                    <input type="hidden" name="listing[latitude]" id="latitude">
                    <input type="hidden" name="listing[longitude]" id="longitude">

                    <!-- Map for location selection -->
                    <div class="mt-3">
                        <label class="form-label">Select Location on Map</label>
                        <div id="map" style="height: 400px; width: 100%; border-radius: 8px;"></div>
                        <div class="mt-2">
                            <button type="button" id="useMyLocation" class="btn btn-outline-primary btn-sm">
                                Use My Current Location
                            </button>
                            <small class="text-muted ms-2">Click on map or use current location to set position</small>
                        </div>
                    </div>

                    <br>
                    <div class="d-flex gap-3 mt-3 mb-3">

                        <button class="btn btn-danger">Add</button>
                        <button type="button" class="btn btn-primary" onclick="history.back()">Back</button>

                    </div>

                </form>
            </div>
        </div>

        <!-- MapLibre CSS -->
        <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" />
        <!-- Custom Map Styles -->
        <style>
            #map {
                cursor: crosshair !important;
            }
            #map:hover {
                cursor: crosshair !important;
            }
            
            /* Alternative cursor options - uncomment to try different styles */
            /* #map { cursor: pointer !important; } */        /* Standard pointer hand */
            /* #map { cursor: cell !important; } */           /* Plus sign cursor */
            /* #map { cursor: copy !important; } */           /* Copy cursor */
            /* #map { cursor: help !important; } */           /* Help cursor */
        </style>
        <!-- MapLibre JS -->
        <script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>
        <!-- Custom Map JS -->
        <script src="/js/map.js"></script>

    </body>