<%layout("/layouts/boilerplate")%>
    <style>
        .filters {
            display: flex;
            flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;

        }

        .filter {
            display: flex;
            flex-direction: column;
            text-align: center;
            margin-top: 1rem;
            margin-right: 2rem;
            opacity: 0.7;
        }

        .filter p {
            font-size: 0.8rem;
        }

        .filter:hover {
            opacity: 1;
        }
        .togle-switch {
             border: 1px solid #ccc;
             padding: 0.5rem;
                border-radius: 20px;
        }
        .form-switch{
            padding : 0.2rem 0.5rem;
        }
         
    </style>


    <div class="filters">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-house"></i></div>
            <p>Entire homes</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p> Castles</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain "></i></div>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-umbrella-beach"></i></div>
            <p> Views</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-list"></i></div>
            <p>All</p>
        </div>

        <div class="togle-switch">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>



    </div>
    <div class="container">
        <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 mt-3 g-4">
            <% for (let listing of allListings) { %>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card col">
                        <img src="<%=listing.image.url%>" class="card-img-top" style="height: 20rem;" alt="...">
                        <div class="card-img-overlay">
                            <%=listing.title%>
                        </div>
                        <div class="card-body">
                            <p class="card-text"> <b>
                                    <%=listing.title%>
                                </b>
                                <br>&#8377;<%=listing.price.toLocaleString("en-IN")%> / night
                                    <i class="tax" style="display: none;">&nbsp;&nbsp;+18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
                <%}%>
        </div>
    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", function () {
            let taxInfo = document.querySelectorAll(".tax");
           taxInfo.forEach(element => {
                if (element.style.display === "none") {
                    element.style.display = "inline";
                } else {
                    element.style.display = "none";
                }
            });

        })
    </script>