<%layout("/layouts/boilerplate")%>
    <style>
        .filters {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2rem;
            overflow-x: auto;
            padding: 1rem 0;
        }

        .filter {
            display: flex;
            flex-direction: column;
            text-align: center;
            text-decoration: none;
            margin-top: 1rem;
            
            opacity: 0.7;
            color:#222;
        }

        .filter p {
            font-size: 0.8rem;
        }

        .filter:hover {
            opacity: 1;
        }

        .togle-switch {
            border: 1px solid #ccc;
            padding: 0.5rem;
            border-radius: 20px;
        }

        .form-switch {
            padding: 0.2rem 0.5rem;
        }
    </style>



    <div class="filters">

        <div><a href="/listings?category=trending" class="filter">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </a></div>

        <div><a href="/listings?category=rooms" class="filter">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a></div>

        <div> <a href="/listings?category=entire-homes" class="filter">
                <div><i class="fa-solid fa-house"></i></div>
                <p>Entire homes</p>
            </a></div>

        <div><a href="/listings?category=iconic-cities" class="filter">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </a></div>

        <div><a href="/listings?category=castles" class="filter">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </a></div>

        <div><a href="/listings?category=mountains" class="filter">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </a></div>

        <div><a href="/listings?category=views" class="filter">
                <div><i class="fa-solid fa-umbrella-beach"></i></div>
                <p>Views</p>
            </a></div>

        <div><a href="/listings?category=pools" class="filter">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </a></div>

        <div><a href="/listings?category=camping" class="filter">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </a></div>

        <div><a href="/listings?category=farms" class="filter">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </a></div>

        <div><a href="/listings?category=arctic" class="filter">
                <div><i class="fa-solid fa-snowflake"></i></div>
                <p>Arctic</p>
            </a></div>

        <div><a href="/listings" class="filter">
                <div><i class="fa-solid fa-list"></i></div>
                <p>All</p>
            </a>
        </div>

    
        <div class="togle-switch">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>



    
    <div class="container">
        <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 mt-3 g-4">
            <% for (let listing of allListings) { %>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card col">
                        <img src="<%=listing.image.url%>" class="card-img-top" style="height: 20rem;" alt="...">
                        <div class="card-img-overlay">
                            <%=listing.title%>
                        </div>
                        <div class="card-body">
                            <p class="card-text"> <b>
                                    <%=listing.title%>
                                </b>
                                <br>&#8377;<%=listing.price.toLocaleString("en-IN")%> / night
                                    <i class="tax" style="display: none;">&nbsp;&nbsp;+18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
                <%}%>
        </div>
    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", function () {
            let taxInfo = document.querySelectorAll(".tax");
            taxInfo.forEach(element => {
                if (element.style.display === "none") {
                    element.style.display = "inline";
                } else {
                    element.style.display = "none";
                }
            });

        })
    </script>